# PostgreSQL connection
DATABASE_URL="postgresql://gcs:gcs@localhost:5432/gcs"

# AES-256-GCM key for encrypting API keys (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-string-here"

# Path to GlobalClaudeSkills root (for seed script)
CLAUDE_ROOT="d:\\GlobalClaudeSkills"

# Secret shared between hook (local machine) and dashboard API
# Generate with: openssl rand -base64 32
HOOK_SECRET="your-hook-secret-here"

# Dashboard URL (used by hook to POST logs)
DASHBOARD_URL="https://gcs-dashboard.zenus.dev"

# Public API URL (if using BFF pattern)
NEXT_PUBLIC_API_URL=http://localhost:4000
